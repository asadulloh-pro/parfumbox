# Copy to repo root .env and apps/api/.env (see apps/api ConfigModule merge order)

# --- API ---
DATABASE_URL="file:./dev.db"
TELEGRAM_BOT_TOKEN="123456:ABC-DEF_from_BotFather"
JWT_SECRET="change-me-to-a-long-random-string"
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
AUTH_DEV_BYPASS=false
PORT=3000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

ADMIN_API_KEY="change-me-admin-key-at-least-8-chars"

# Public base URL for local-disk uploads when MinIO is not used (defaults to http://localhost:PORT)
# PUBLIC_BASE_URL="https://api.yourdomain.com"

# MinIO (S3-compatible). When MINIO_ENDPOINT is set, uploads go to the bucket below (local /uploads is not used).
# MINIO_ENDPOINT="http://127.0.0.1:9000"
# MINIO_ACCESS_KEY="minioadmin"
# MINIO_SECRET_KEY="minioadmin"
# MINIO_BUCKET="parfumbox"
# MINIO_REGION="us-east-1"
# Optional: public URL prefix for stored objects (CDN or console proxy). Defaults to {MINIO_ENDPOINT}/{MINIO_BUCKET}
# MINIO_PUBLIC_URL="http://127.0.0.1:9000/parfumbox"

# --- Web ---
VITE_API_URL="http://localhost:3000"
