# Copy to apps/api/.env and apps/web/.env.local as needed

# --- API (apps/api/.env) ---
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/parfumbox"
TELEGRAM_BOT_TOKEN="123456:ABC-DEF_from_BotFather"
JWT_SECRET="change-me-to-a-long-random-string"
# Optional: reject initData older than this many seconds (default 86400)
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
# Dev only: set to "true" to accept X-Dev-User-Id header (NEVER in production)
AUTH_DEV_BYPASS=false
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# --- Web (apps/web/.env.local) ---
VITE_API_URL="http://localhost:3000"
