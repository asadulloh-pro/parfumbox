generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Telegram mini-app user; keyed by Telegram account id.
model User {
  id                 String    @id @default(cuid())
  telegramId         String    @unique
  telegramUsername   String?
  firstName          String?
  lastName           String?
  /// Mini-app / Telegram UI language: ru | uz (used for bot messages).
  locale             String    @default("uz")
  phone              String?
  birthDate          DateTime? @db.Date
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orders Order[]
}

/// Admin panel account (separate from Telegram users).
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notificationReads AdminNotificationRead[]
}

enum AdminNotificationKind {
  ORDER_CREATED
  ORDER_UPDATED
}

model AdminNotification {
  id        String                @id @default(cuid())
  kind      AdminNotificationKind
  orderId   String
  createdAt DateTime              @default(now())

  reads AdminNotificationRead[]

  @@index([createdAt])
}

model AdminNotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  adminUserId    String
  readAt         DateTime @default(now())

  notification AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  admin        AdminUser           @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([notificationId, adminUserId])
  @@index([adminUserId])
}

/// Reusable volume options (hajm). Prices are set per product, not here.
model ProductSizePreset {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  grams     Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  /// Catalog listing: 10 g line if present, else smallest price among sizes.
  priceUzs    Int
  /// [{ "presetId": "<cuid>", "priceUzs": <integer> }, ...]
  sizes       Json?
  images      String[] @default([])
  stock       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id                 String      @id @default(cuid())
  userId             String
  status             OrderStatus @default(PENDING)
  subtotalUzs        Int
  totalUzs           Int
  deliveryPhone      String?
  deliveryFirstName  String?
  deliveryLastName   String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
}

model OrderItem {
  id                String @id @default(cuid())
  orderId           String
  productId         String?
  quantity          Int
  unitPriceUzs      Int
  titleSnapshot     String
  sizeId            String?
  sizeLabelSnapshot String?
  gramsSnapshot     Int?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}
