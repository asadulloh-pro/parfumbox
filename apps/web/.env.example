# Base URL for the Nest API (no trailing slash). Defaults to http://localhost:3000 if unset.
# VITE_API_BASE_URL=http://localhost:3000

# Optional: paste a short-lived user JWT from the API (e.g. after POST /auth/telegram) to test
# the mini app in a normal browser. Never commit real tokens. Server-only secrets stay in apps/api/.env
# VITE_DEV_JWT=
