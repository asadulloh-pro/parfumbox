# Base URL for the Nest API (no trailing slash). Production default is http://localhost:3000 if unset.
# In `vite dev`, the app uses `/_parfumbox-api` (proxied to port 3000) so Telegram + one ngrok to Vite works.
# Set this for production builds or when you want the browser to talk to the API directly:
# VITE_API_BASE_URL=https://api.example.com

# Browser-only dev sign-in (not Telegram): both must be set, then restart Vite.
# VITE_DEV=true
# VITE_DEV_JWT=paste-a-valid-user-jwt-from-the-api
