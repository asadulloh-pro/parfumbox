{
  "name": "parfumbox",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:web:tunnel": "concurrently -k -n web,ngrok -c cyan,magenta \"pnpm --filter web dev\" \"ngrok http 5173\"",
    "dev:admin": "pnpm --filter admin dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
